DATABASE_URL="postgresql://postgres:postgres@localhost:5432/eoffice_tiara?schema=public"

# Secret untuk JWT session + HMAC signature verifikasi QR.
# WAJIB random 48+ karakter. Setelah deploy JANGAN ubah (akan menginvalidasi semua signature).
# Generate: node -e "console.log(require('crypto').randomBytes(48).toString('hex'))"
JWT_SECRET="ganti-dengan-string-random-minimal-48-karakter"

# URL publik aplikasi (dipakai QR code & verifikasi).
NEXT_PUBLIC_APP_URL="http://localhost:3000"

# Vercel Blob — wajib di production (Vercel / serverless).
# Untuk development dengan filesystem lokal, boleh dikosongkan.
BLOB_READ_WRITE_TOKEN=

# Opsional: allowed origins untuk CSRF same-origin enforcement (comma separated).
# Default = NEXT_PUBLIC_APP_URL.
# ALLOWED_ORIGINS="https://eoffice.tiara.co.id,https://www.eoffice.tiara.co.id"
